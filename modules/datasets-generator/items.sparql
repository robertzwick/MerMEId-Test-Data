prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix melod: <https://lod.academy/melod/vocab/ontology#>
prefix skos: <http://www.w3.org/2004/02/skos/core#>
prefix schema: <https://schema.org/>
prefix terms: <https://lod.academy/melod/vocab/terms#>

construct {
  ?item_iri a melod:ItemEntity ;
  	skos:prefLabel ?label .
} where {
  select ?item_iri ?label where {
    ?item_iri a melod:Item .
    ?item_iri rdfs:label ?item_name .
    bind(?item_name AS ?label)
  }
  order by ?label
}