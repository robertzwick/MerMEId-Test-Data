<urn:uuid:1031334055> a melod:Work;
    melod:hasTitle _:f9fcd98c-36ca-49b8-9907-059a34649a5f, _:9c302f19-8003-43f0-b0aa-61f70b71bd47, _:1e4c657e-fd1c-43c3-bec0-29f9f69942c6;
